{
  "kind": "collectionType",
  "collectionName": "applications",
  "info": {
    "singularName": "application",
    "pluralName": "applications",
    "displayName": "Заявка"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "message": {
      "type": "text",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["new", "in_progress", "done"],
      "default": "new"
    },
    "source": {
      "type": "string"
    },
    "consentGiven": {
      "type": "boolean",
      "default": false
    },
    "consentAt": {
      "type": "datetime"
    }
  }
}
