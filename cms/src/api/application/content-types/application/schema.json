{
  "kind": "collectionType",
  "collectionName": "applications",
  "info": {
    "singularName": "application",
    "pluralName": "applications",
    "displayName": "Заявка"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "label": "Имя"
    },
    "phone": {
      "type": "string",
      "required": true,
      "label": "Телефон"
    },
    "message": {
      "type": "text",
      "required": true,
      "label": "Сообщение"
    },
    "status": {
      "type": "enumeration",
      "enum": ["new", "in_progress", "done"],
      "default": "new",
      "label": "Статус"
    },
    "source": {
      "type": "string",
      "label": "Источник"
    },
    "consentGiven": {
      "type": "boolean",
      "default": false,
      "label": "Согласие получено"
    },
    "consentAt": {
      "type": "datetime",
      "label": "Дата согласия"
    }
  }
}
